MEETSTREAM_API_KEY=
WEBHOOK_BASE_URL=           # ngrok HTTPS URL pointing at server.py (port 3001)

# Scalekit credentials (used for all connectors — Google Calendar, Gmail, etc.)
SCALEKIT_ENV_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
# Gmail connector uses the same Scalekit credentials above.
# User must authorize Gmail separately via the auth link printed on first run.

# Dashboard backend (default: http://localhost:3000)
BACKEND_URL=http://localhost:3000

# Required by backend/main.py for GPT-4o summarization
OPENAI_API_KEY=
