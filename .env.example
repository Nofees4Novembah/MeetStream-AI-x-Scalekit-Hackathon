# ── MeetStream / webhook server ──────────────────────────────────────────────
MEETSTREAM_API_KEY=
WEBHOOK_BASE_URL=           # ngrok HTTPS URL pointing at server.py (port 3001)

# ── Scalekit (Google Calendar, Gmail connectors) ──────────────────────────────
SCALEKIT_ENV_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
# Gmail uses the same credentials — user must authorize via link on first run.

# ── Dashboard backend ─────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3000
OPENAI_API_KEY=             # Required by backend/main.py for GPT-4o summarization

# ── Bridge (real-time in-meeting AI agent) ────────────────────────────────────
PORT=8000

# Optional bridge tuning (see README):
# MEETSTREAM_BOT_NAME=My Assistant
# MEETSTREAM_IGNORE_SPEAKERS=Some Bot Name,Another Name
# AGENT_SPEAKER_KEYWORDS=bot,agent,assistant,ai
# MEETSTREAM_IN_RATE=48000
# MEETSTREAM_OUT_RATE=48000
# MODEL_AUDIO_RATE=24000
# MEETSTREAM_OUT_AUDIO_CHUNK_MS=240
# MEETSTREAM_SENDAUDIO_PACE_MS=0

# Optional MCP servers (see docs/mcp.md):
# MCP_CONFIG=/path/to/mcp.config.json
# FRAMER_MCP_SSE_URL=
# N8N_MCP_REMOTE_URL=
# DOCKER_MCP_ENABLED=0
# DOCKER_MCP_URL=
# DOCKER_MCP_BEARER_TOKEN=
# DOCKER_MCP_SESSION_TIMEOUT=120
